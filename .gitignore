# venv (junction local; venv real fica em Z:\venvs\pdf2md)
.venv/

# caches Python (devem estar em Z:\caches via env vars)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# IDE/editor
.idea/
*.swp
*.swo
*~
.vscode/

# corpus — política de 3 tiers (ver corpus/registry.py + corpus/examples/README.md)
#
# tier ZCACHE: fontes livres pesadas/recuperáveis — bytes NÃO vão pro git (só ref no
# registry). Manifests humanos em docs/reference/corpus/.
corpus/_sources/*
!corpus/_sources/MANIFEST.md
corpus/_canonical/*
!corpus/_canonical/MANIFEST.md
#
# tier IN-REPO: corpus/examples/ É versionado (prova pronta — excertos livres pequenos).
# NÃO ignorar. (regra explícita p/ deixar claro que é intencional)
!corpus/examples/
#
# tier PRIVATE: material proprietary (Nielsen & Chuang QCQI — copyright Cambridge).
# corpus/nielsen_chuang/ foi PURGADO do histórico em 2026-05-31 (git filter-repo).
# Source vive read-only no AulaQuantum; output de uso volta pra lá. Ver corpus/RIGHTS.md.
# Regra abaixo impede re-add acidental.
corpus/nielsen_chuang/

# diretórios temp do pipeline
/tmp_*/
/temp_*/

# outputs de experimentos da bancada suja (cada lab/eNN/.gitignore pode override)
lab/*/out/

# build / dist
dist/
build/
*.egg-info/
