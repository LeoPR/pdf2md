# venv (junction local; venv real fica em Z:\venvs\pdf2md)
.venv/

# caches Python (devem estar em Z:\caches via env vars)
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# IDE/editor
.idea/
*.swp
*.swo
*~
.vscode/

# corpus — PDFs originais não vão pro git (refs ficam via MANIFEST.md, PDFs não)
corpus/_sources/*
!corpus/_sources/MANIFEST.md
corpus/_canonical/*
!corpus/_canonical/MANIFEST.md

# Material derivado de fontes proprietary (Nielsen & Chuang QCQI — copyright Cambridge).
# Já versionado no init (commit be19f01); ver docs/LICENSING.md para opções de purge se
# o repo for empurrado público. A regra abaixo evita NOVOS adds desse dir.
corpus/nielsen_chuang/

# diretórios temp do pipeline
/tmp_*/
/temp_*/

# outputs de experimentos da bancada suja (cada lab/eNN/.gitignore pode override)
lab/*/out/

# build / dist
dist/
build/
*.egg-info/
